# Local deployment testing configuration
# Copy this to .env and fill in your values, then source it before running script-local

# Required: Path to workspace (usually the project root)
WORKSPACE=/path/to/project

# Required: Comma-separated script paths relative to workspace
SCRIPTS=deploy

# Required: SSH host to deploy to
DEPLOY_HOST=example.com

# Required: SSH user
DEPLOY_USER=deploy

# Optional: SSH port (default: 22)
DEPLOY_PORT=22

# Optional: Path to SSH private key file
# If not set, will use $SSH_PRIVATE_KEY environment variable
# If that's also not set, will use ~/.ssh/id_rsa
SSH_KEY_PATH=~/.ssh/deploy_key

# Optional: Environment variable name containing SSH private key
# (default: SSH_PRIVATE_KEY)
SSH_KEY_ENV=SSH_PRIVATE_KEY

# Optional: Host public key for verification (pin this in production)
# Get it with: ssh-keyscan example.com | grep ssh-ed25519
# HOST_KEY="ssh-ed25519 AAAA..."

# Optional: Connection timeout (default: 30s)
SSH_TIMEOUT=30s

# Optional: For testing with a staging/different environment
# DEPLOY_ENV=staging
